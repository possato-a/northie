# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Segurança ─────────────────────────────────────────────────────────────────
# Chave de 32 chars para encriptar tokens de integração (AES-256)
ENCRYPTION_KEY=<32-chars-random-string>
# JWT secret para autenticação interna
JWT_SECRET=<base64-random-string>
# Secret para proteger endpoint do cron job da Vercel — gere com: openssl rand -hex 32
CRON_SECRET=<random-hex-secret>

# ── Meta Ads ──────────────────────────────────────────────────────────────────
META_APP_ID=<meta-app-id>
META_APP_SECRET=<meta-app-secret>

# ── Hotmart ───────────────────────────────────────────────────────────────────
HOTMART_CLIENT_ID=<hotmart-app-client-id>
HOTMART_CLIENT_SECRET=<hotmart-app-client-secret>
# Token estático configurado no painel da Hotmart (Ferramentas > Webhooks > Hottok)
HOTMART_WEBHOOK_TOKEN=<hotmart-webhook-token>

# ── Google Ads (opcional — necessário para integração Google) ─────────────────
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
# Developer token obtido em: https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=<google-ads-developer-token>

# ── URL do backend (usado em callbacks OAuth) ─────────────────────────────────
# Em desenvolvimento: http://localhost:3001
# Em produção: URL do seu projeto na Vercel
BACKEND_URL=https://<seu-projeto>.vercel.app
