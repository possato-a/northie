# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# Em desenvolvimento: http://localhost:3001 | Em produção: URL da Vercel
BACKEND_URL=https://<seu-projeto>.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Segurança ─────────────────────────────────────────────────────────────────
# Chave de 32 chars para encriptar tokens OAuth (AES-256) — gere com: openssl rand -hex 16
ENCRYPTION_KEY=<32-chars-random-string>
# JWT secret para autenticação interna — gere com: openssl rand -base64 64
JWT_SECRET=<base64-random-string>
# Secret para proteger endpoint do cron job da Vercel — gere com: openssl rand -hex 32
CRON_SECRET=<random-hex-secret>

# ── Anthropic (IA) ────────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-<sua-chave>

# ── Meta Ads ──────────────────────────────────────────────────────────────────
# Obtenha em: https://developers.facebook.com/apps/
META_APP_ID=<meta-app-id>
META_APP_SECRET=<meta-app-secret>

# ── Hotmart ───────────────────────────────────────────────────────────────────
# Obtenha em: https://developers.hotmart.com/
HOTMART_CLIENT_ID=<hotmart-app-client-id>
HOTMART_CLIENT_SECRET=<hotmart-app-client-secret>
# Token estático configurado no painel da Hotmart (Ferramentas > Webhooks > Hottok)
HOTMART_WEBHOOK_TOKEN=<hotmart-webhook-token>

# ── Google Ads ────────────────────────────────────────────────────────────────
# Client ID e Secret: console.cloud.google.com → APIs e Serviços → Credenciais → OAuth 2.0
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
# Developer Token: ads.google.com → conta de administrador (MCC) → Ferramentas → Centro de API
GOOGLE_ADS_DEVELOPER_TOKEN=<google-ads-developer-token>

# ── Stripe Connect ────────────────────────────────────────────────────────────
# Obtenha em: https://dashboard.stripe.com/settings/connect
# STRIPE_CLIENT_ID: "ca_..." — ID do app Connect da Northie (plataforma)
STRIPE_CLIENT_ID=ca_<stripe-connect-client-id>
# STRIPE_SECRET_KEY: chave secreta da conta Northie (sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=sk_test_<stripe-secret-key>
# STRIPE_WEBHOOK_SECRET: "whsec_..." — obtido no Stripe Dashboard > Webhooks após registrar o endpoint
STRIPE_WEBHOOK_SECRET=whsec_<stripe-webhook-secret>
