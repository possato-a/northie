# ═══════════════════════════════════════════════════════════════════════════════
# Northie Backend — Environment Variables
# Copie este arquivo para .env (local) ou configure no painel da Vercel (produção)
# NUNCA commite o .env com valores reais — está no .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# URL base do backend — usada para construir redirect URIs do OAuth e webhook URLs
# Dev: http://localhost:3001 | Prod: https://northie.vercel.app
BACKEND_URL=https://northie.vercel.app
# URL do frontend — usada no postMessage do callback OAuth para fechar o popup
# Dev: http://localhost:5173 | Prod: https://northie.vercel.app
FRONTEND_URL=https://northie.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtenha em: Supabase Dashboard > Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Senha do banco — usada em scripts de migração diretos via pg
POSTGRES_PASSWORD=<db-password>

# ── Segurança ─────────────────────────────────────────────────────────────────
# Chave AES-256 para encriptar tokens OAuth no banco — EXATAMENTE 32 chars
# Gere com: openssl rand -hex 16
ENCRYPTION_KEY=<32-chars-random-string>
# JWT secret para autenticação interna
# Gere com: openssl rand -base64 64
JWT_SECRET=<base64-random-string>
# Secret para proteger endpoint do cron job da Vercel
# Gere com: openssl rand -hex 32
CRON_SECRET=<random-hex-secret>
# Secret para assinar/verificar o state token do OAuth (CSRF protection)
# Pode ser o mesmo valor do CRON_SECRET
OAUTH_STATE_SECRET=<random-hex-secret>

# ── Anthropic (IA) ────────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-<sua-chave>

# ── Meta Ads ──────────────────────────────────────────────────────────────────
# Obtenha em: https://developers.facebook.com/apps/ > seu app > Configurações básicas
META_APP_ID=<meta-app-id>
META_APP_SECRET=<meta-app-secret>

# ── Google Ads ────────────────────────────────────────────────────────────────
# Client ID e Secret: console.cloud.google.com > APIs e Serviços > Credenciais > OAuth 2.0
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
# Developer Token: ads.google.com > conta MCC > Ferramentas > Centro de API
GOOGLE_ADS_DEVELOPER_TOKEN=<google-ads-developer-token>

# ── Hotmart ───────────────────────────────────────────────────────────────────
# Obtenha em: https://developers.hotmart.com/ > Meus Apps > seu app
HOTMART_CLIENT_ID=<hotmart-client-id>
HOTMART_CLIENT_SECRET=<hotmart-client-secret>
# Token estático (hottok) — configurado no painel Hotmart > Ferramentas > Webhook
# Obtenha o valor na tela de configuração do webhook
HOTMART_WEBHOOK_TOKEN=<hotmart-webhook-hottok>
# HMAC Secret — para verificação via x-hotmart-signature (API v2.0, mais seguro)
# Deixe em branco se usar apenas hottok
HOTMART_WEBHOOK_SECRET=

# ── Stripe Connect ────────────────────────────────────────────────────────────
# Documentação completa: docs/integrations/setup-stripe-hotmart.md

# Chave secreta da conta Northie (plataforma)
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_<stripe-secret-key>

# Client ID do Connect Platform — começa com "ca_"
# Obtenha em: https://dashboard.stripe.com/settings/connect > "Your platform's client ID"
STRIPE_CLIENT_ID=ca_<stripe-connect-client-id>

# Webhook signing secret — começa com "whsec_"
# Obtenha em: https://dashboard.stripe.com/webhooks após registrar o endpoint
# Endpoint: https://northie.vercel.app/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_<stripe-webhook-secret>

# ── Shopify ────────────────────────────────────────────────────────────────────
# Obtenha em: https://partners.shopify.com/ > Apps > seu app > Client credentials
SHOPIFY_API_KEY=<shopify-api-key>
SHOPIFY_API_SECRET=<shopify-api-secret>
# Deve ser o mesmo valor de SHOPIFY_API_SECRET — Shopify usa o client secret para assinar webhooks
SHOPIFY_WEBHOOK_SECRET=<mesmo-valor-do-shopify-api-secret>

# ── Resend (Email) ────────────────────────────────────────────────────────────
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_<resend-api-key>
# Webhook signing secret — Resend > Webhooks > seu endpoint
RESEND_WEBHOOK_SECRET=<resend-webhook-secret>
