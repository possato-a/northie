{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/main"
        }
    ],
    "functions": {
        "api/main.ts": {
            "maxDuration": 300
        }
    },
    "headers": [
        {
            "source": "/",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        },
        {
            "source": "/index.html",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/api/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/cron/sync",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/cron/reports",
            "schedule": "0 8 * * *"
        }
    ]
}